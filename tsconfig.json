{
    "compilerOptions": {
        "sourceMap": true,
        "noImplicitAny": true,
        "module": "ESNext",
        "lib": ["ES2020", "DOM"],
        "target": "ES2020",
        "allowJs": true,
        "moduleResolution": "bundler",
        "isolatedModules": true,
        "esModuleInterop": true,
        "skipLibCheck": true
    }
}